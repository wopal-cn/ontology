# 使用 Debian slim 作为轻量级的 Linux 国内加速基础镜像
FROM debian:bookworm-slim

# 定义可配置的工具版本参数
ARG NVM_VERSION=v0.40.1
ARG GO_VERSION=1.23.4

# 配置 APT 镜像 (Aliyun)
RUN echo "deb http://mirrors.aliyun.com/debian bookworm main contrib non-free" > /etc/apt/sources.list && \
    echo "deb http://mirrors.aliyun.com/debian bookworm-updates main contrib non-free" >> /etc/apt/sources.list && \
    echo "deb http://mirrors.aliyun.com/debian-security bookworm-security main contrib non-free" >> /etc/apt/sources.list && \
    rm -rf /etc/apt/sources.list.d/*

# 安装基础依赖包和 AI 智能体编码时常用的系统工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl bash ca-certificates sudo zip unzip wget gnupg \
    lsb-release apt-transport-https software-properties-common \
    ripgrep fd-find jq tree less procps tmux lsof \
    python3 python3-pip python3-venv xz-utils docker.io \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 权限的默认用户 'coder'，并赋予其无密码执行 sudo 的权限
RUN useradd -m -s /bin/bash -u 1000 coder && \
    echo "coder ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 切换到 coder 用户，针对此用户安装各项编程运行环境 (SDK)
USER coder
WORKDIR /home/coder

# 注入全部国内全链路镜像加速变量
ENV NVM_DIR="/home/coder/.nvm" \
    BUN_INSTALL="/home/coder/.bun" \
    RUSTUP_HOME="/home/coder/.rustup" \
    CARGO_HOME="/home/coder/.cargo" \
    GOPATH="/home/coder/go" \
    NVM_NODEJS_ORG_MIRROR="https://npmmirror.com/mirrors/node/" \
    UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple" \
    GOPROXY="https://goproxy.cn,direct" \
    RUSTUP_DIST_SERVER="https://rsproxy.cn" \
    RUSTUP_UPDATE_ROOT="https://rsproxy.cn/rustup" \
    PUB_HOSTED_URL="https://pub.flutter-io.cn" \
    FLUTTER_STORAGE_BASE_URL="https://storage.flutter-io.cn"
ENV PATH="/home/coder/.flutter-sdk/bin:$CARGO_HOME/bin:/usr/local/go/bin:$GOPATH/bin:$BUN_INSTALL/bin:$NVM_DIR/default:/home/coder/.local/bin:$PATH"

# 安装 Node.js (NVM) 和 ast-grep (底层 npm 修改为国内仓库指向)
RUN curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" | bash && \
    bash -c "source $NVM_DIR/nvm.sh && \
    nvm install --lts && \
    nvm alias default node && \
    nvm use default && \
    ln -sf \$(dirname \$(which node)) $NVM_DIR/default && \
    npm config set registry https://registry.npmmirror.com/ && \
    npm install -g @ast-grep/cli opencode-ai@latest"

# 安装 uv 和 Bun
RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    curl -fsSL https://bun.sh/install | bash

# 安装 Go 语言（使用阿里云极速节点）
USER root
RUN curl -OL https://mirrors.aliyun.com/golang/go${GO_VERSION}.linux-$(dpkg --print-architecture).tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-$(dpkg --print-architecture).tar.gz && \
    rm go${GO_VERSION}.linux-$(dpkg --print-architecture).tar.gz
USER coder

# 安装 Rust 与全局 Cargo 替换源 (rsproxy.cn)
RUN curl --proto '=https' --tlsv1.2 -sSf https://rsproxy.cn/rustup-init.sh | sh -s -- -y --no-modify-path && \
    mkdir -p $CARGO_HOME && \
    echo '[source.crates-io]\nreplace-with = "rsproxy-sparse"\n[source.rsproxy-sparse]\nregistry = "sparse+https://rsproxy.cn/index/"\n[net]\ngit-fetch-with-cli = true' > $CARGO_HOME/config.toml

# 安装 Flutter (替换为极速的 Gitee Mirror 克隆)
RUN git clone https://gitee.com/mirrors/Flutter.git -b stable /home/coder/.flutter-sdk

# 针对基础环境目录进行权限平权
USER root
RUN mkdir -p /home/coder/.config/opencode \
    /home/coder/.local/share/opencode \
    /home/coder/.cache/opencode \
    /home/coder/.cache/oh-my-opencode \
    /home/coder/.npm \
    /home/coder/go \
    && chown -R coder:coder /home/coder

# 将 /workspace 指定为容器进入后的默认工作目录（此目录会作为宿主机的项目挂载点）
WORKDIR /workspace

# 复制入口处理脚本并赋予可执行权限
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# 设定入口点。所有命令在执行前都会先跳入 entrypoint.sh 做权限桥接处理
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
# 在没有额外提供指令时，默认启动 opencode
CMD ["opencode"]
