# 基础镜像 + APT 源配置（极少变化）
FROM debian:bookworm-slim

ARG GO_VERSION=1.23.4
ARG SANDBOX_VERSION=1.0.0

RUN echo "deb http://mirrors.aliyun.com/debian bookworm main contrib non-free" > /etc/apt/sources.list && \
    echo "deb http://mirrors.aliyun.com/debian bookworm-updates main contrib non-free" >> /etc/apt/sources.list && \
    echo "deb http://mirrors.aliyun.com/debian-security bookworm-security main contrib non-free" >> /etc/apt/sources.list && \
    rm -rf /etc/apt/sources.list.d/*

# 系统工具（极少变化，安装慢）
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget bash ca-certificates sudo zip unzip gnupg \
    lsb-release apt-transport-https software-properties-common \
    ripgrep fd-find jq tree less procps tmux lsof make iputils-ping \
    python3 python3-pip python3-venv xz-utils docker.io \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libasound2 libpango-1.0-0 libcairo2 \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && ln -sf /usr/bin/pip3 /usr/bin/pip \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI（直接下载 deb 包）
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then GH_ARCH="amd64"; elif [ "$ARCH" = "arm64" ]; then GH_ARCH="arm64"; fi && \
    curl -fsSL https://github.com/cli/cli/releases/download/v2.62.0/gh_2.62.0_linux_${GH_ARCH}.deb -o /tmp/gh.deb && \
    apt-get update && apt-get install -y /tmp/gh.deb && \
    rm /tmp/gh.deb && \
    rm -rf /var/lib/apt/lists/*

# 创建用户（极少变化）
RUN useradd -m -s /bin/bash -u 1000 coder && \
    echo "coder ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Go（安装慢，版本偶尔变化）
RUN ARCH=$(dpkg --print-architecture) && \
    curl -OL https://mirrors.aliyun.com/golang/go${GO_VERSION}.linux-${ARCH}.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-${ARCH}.tar.gz && \
    rm go${GO_VERSION}.linux-${ARCH}.tar.gz

# Node.js（版本偶尔变化）
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then NODE_ARCH="x64"; elif [ "$ARCH" = "arm64" ]; then NODE_ARCH="arm64"; fi && \
    wget -q https://npmmirror.com/mirrors/node/v22.12.0/node-v22.12.0-linux-${NODE_ARCH}.tar.xz -O /tmp/node.tar.xz && \
    tar -xJf /tmp/node.tar.xz -C /usr/local && \
    mv /usr/local/node-v22.12.0-linux-${NODE_ARCH} /usr/local/node && \
    rm /tmp/node.tar.xz

# 环境变量 + 切换用户
ENV BUN_INSTALL="/home/coder/.bun" \
    RUSTUP_HOME="/home/coder/.rustup" \
    CARGO_HOME="/home/coder/.cargo" \
    GOPATH="/home/coder/go" \
    UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple" \
    GOPROXY="https://goproxy.cn,direct" \
    RUSTUP_DIST_SERVER="https://rsproxy.cn" \
    RUSTUP_UPDATE_ROOT="https://rsproxy.cn/rustup" \
    PUB_HOSTED_URL="https://pub.flutter-io.cn" \
    FLUTTER_STORAGE_BASE_URL="https://storage.flutter-io.cn"

ENV PATH="/usr/local/node/bin:/home/coder/.flutter-sdk/bin:$CARGO_HOME/bin:/usr/local/go/bin:$GOPATH/bin:$BUN_INSTALL/bin:/home/coder/.local/bin:$PATH"

USER coder
WORKDIR /home/coder

# 配置 npm 镜像源
RUN npm config set registry https://registry.npmmirror.com/ -g

# Node 全局工具 - pnpm（安装快）
RUN npm install -g @ast-grep/cli pnpm

# Playwright + chromium（安装慢）
ENV PLAYWRIGHT_BROWSERS_PATH=/home/coder/.cache/ms-playwright
RUN npm install -g playwright && \
    mkdir -p $PLAYWRIGHT_BROWSERS_PATH && \
    ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then CHROME_ARCH="linux64"; elif [ "$ARCH" = "arm64" ]; then CHROME_ARCH="linux64"; fi && \
    curl -fsSL https://registry.npmmirror.com/-/binary/chrome-for-testing/146.0.7680.31/${CHROME_ARCH}/chrome-linux64.zip -o /tmp/chrome.zip && \
    unzip -q /tmp/chrome.zip -d /tmp && \
    mv /tmp/chrome-linux64 $PLAYWRIGHT_BROWSERS_PATH/chromium-1214 && \
    rm /tmp/chrome.zip

# Rust（安装慢，版本偶尔变化）
RUN curl --proto '=https' --tlsv1.2 -sSf https://rsproxy.cn/rustup-init.sh | sh -s -- -y --no-modify-path && \
    mkdir -p $CARGO_HOME && \
    printf '[source.crates-io]\nreplace-with = "rsproxy-sparse"\n[source.rsproxy-sparse]\nregistry = "sparse+https://rsproxy.cn/index/"\n[net]\ngit-fetch-with-cli = true\n' > $CARGO_HOME/config.toml

# Flutter（安装慢，版本偶尔变化）
RUN git clone --depth 1 https://gitee.com/mirrors/Flutter.git -b stable /home/coder/.flutter-sdk

# uv（使用 gh-proxy 加速）
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then UV_ARCH="x86_64-unknown-linux-gnu"; \
    elif [ "$ARCH" = "arm64" ]; then UV_ARCH="aarch64-unknown-linux-gnu"; fi && \
    mkdir -p /home/coder/.local/bin && \
    curl -fsSL https://gh-proxy.com/https://github.com/astral-sh/uv/releases/download/0.10.9/uv-${UV_ARCH}.tar.gz | tar -xzf - -C /home/coder/.local/bin && \
    mv /home/coder/.local/bin/uv-${UV_ARCH}/uv /home/coder/.local/bin/ && \
    rm -rf /home/coder/.local/bin/uv-${UV_ARCH}

# Bun（使用 gh-proxy 加速）
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then BUN_ARCH="x64"; \
    elif [ "$ARCH" = "arm64" ]; then BUN_ARCH="aarch64"; fi && \
    curl -fsSL https://gh-proxy.com/https://github.com/oven-sh/bun/releases/download/bun-v1.3.10/bun-linux-${BUN_ARCH}.zip -o /tmp/bun.zip && \
    unzip -q /tmp/bun.zip -d /home/coder && \
    rm /tmp/bun.zip

# 目录权限准备
USER root
RUN mkdir -p /home/coder/.config/opencode \
    /home/coder/.local/share/opencode \
    /home/coder/.cache/opencode \
    /home/coder/.npm \
    /home/coder/go \
    /shared/opencode/commands \
    /shared/opencode/plugins \
    /shared/opencode/rules \
    /shared/opencode/skills \
    /shared/opencode/agents \
    && chown -R coder:coder /home/coder /shared
USER coder

# 频繁变动层（opencode, openspec）
ARG OPENCODE_BUILD_TIME=0
RUN npm install -g opencode-ai@latest
RUN npm install -g @fission-ai/openspec@latest

# 入口点配置
USER root
WORKDIR /project

# 时区设置（放最后避免缓存失效）
RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

LABEL org.opencontainers.image.version="${SANDBOX_VERSION}" \
      org.opencontainers.image.title="Wopal Agent Sandbox (CN)" \
      org.opencontainers.image.description="Isolated Docker sandbox for AI agents with CN mirrors"

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD pgrep -f "opencode serve" >/dev/null || exit 1

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["opencode"]
