{
  "name": "wopal-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "wopal": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x bin/cli.js",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "p-limit": "^7.3.0",
    "picocolors": "^1.1.1",
    "simple-git": "^3.32.3",
    "strip-json-comments": "^5.0.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.15",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
